{
  "name": "fictrio",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "db:generate": "bun run --cwd apps/api prisma generate",
    "db:migrate": "bun run --cwd apps/api prisma migrate dev",
    "db:grant-role": "bun run --cwd apps/api db:grant-role",
    "db:seed:social": "bun apps/api/prisma/social-seed.ts",
    "db:studio": "bun run --cwd apps/api prisma studio",
    "content:candidates:movies": "bun apps/api/prisma/content-import/1-discover-movie-candidates.ts",
    "content:candidates:shows": "bun apps/api/prisma/content-import/2-discover-show-candidates.ts",
    "content:candidates:books": "bun apps/api/prisma/content-import/3-discover-book-candidates.ts",
    "content:fetch:movies": "bun apps/api/prisma/content-import/4-fetch-movies.ts",
    "content:fetch:shows": "bun apps/api/prisma/content-import/5-fetch-shows.ts",
    "content:fetch:books": "bun apps/api/prisma/content-import/6-fetch-books.ts",
    "content:import:movies": "bun apps/api/prisma/content-import/7-import-movies.ts",
    "content:import:shows": "bun apps/api/prisma/content-import/8-import-shows.ts",
    "content:import:books": "bun apps/api/prisma/content-import/9-import-books.ts",
    "content:delete": "bun apps/api/prisma/content-import/delete-content.ts",
    "content:delete:movies": "bun apps/api/prisma/content-import/delete-content.ts movies",
    "content:delete:shows": "bun apps/api/prisma/content-import/delete-content.ts shows",
    "content:delete:books": "bun apps/api/prisma/content-import/delete-content.ts books",
    "content:delete:all": "bun apps/api/prisma/content-import/delete-content.ts all",
    "lint": "turbo lint",
    "format": "prettier --write .",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.9.0",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3"
  }
}
