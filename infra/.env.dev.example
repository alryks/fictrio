# Development environment. Copy to infra/.env.dev:
#   cp infra/.env.dev.example infra/.env.dev
#
# Used by:
#   - the full dev stack (infra/docker-compose.dev.yml) via --env-file;
#   - host runs (`bun run dev`, `bun run db:*`, tests), which read
#     ../../infra/.env.dev relative to apps/api.
#
# POSTGRES_HOST/REDIS_HOST are localhost here so host processes reach the
# containers through the published ports; the api container overrides them to
# the compose service names (postgres/redis).

NODE_ENV=development

API_HOST=0.0.0.0
API_PORT=3001
JWT_SECRET=replace-me-with-a-long-random-secret
JWT_ACCESS_TOKEN_EXPIRES_IN=1h

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=fictrio
POSTGRES_USER=fictrio
POSTGRES_PASSWORD=fictrio

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=fictrio
REDIS_PASSWORD=fictrio

NEXT_PUBLIC_API_URL=http://localhost:3001

TMDB_API_KEY=
TMDB_API_BASE_URL=https://api.themoviedb.org/3
IMPORT_TMDB_MOVIE_PAGES=2
IMPORT_TMDB_SHOW_PAGES=2
IMPORT_TMDB_SEASONS_PER_SHOW=

OPEN_LIBRARY_API_BASE_URL=https://openlibrary.org
OPEN_LIBRARY_COVERS_BASE_URL=https://covers.openlibrary.org
IMPORT_OPEN_LIBRARY_BOOK_LIMIT=50
IMPORT_OPEN_LIBRARY_SUBJECT=fiction
