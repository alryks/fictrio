# Frontend
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# API
API_PORT=3001

JWT_SECRET=your-secret
JWT_ACCESS_TOKEN_EXPIRES_IN=1h

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=fictrio
