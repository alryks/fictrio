POSTGRES_PASSWORD=fictrio

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USERNAME=fictrio
REDIS_PASSWORD=fictrio

# External metadata import
TMDB_API_KEY=your-api-key
TMDB_REQUEST_DELAY_MS=300
OPEN_LIBRARY_USER_AGENT=MyApp (contact@example.org)
OPEN_LIBRARY_REQUEST_DELAY_MS=1100
