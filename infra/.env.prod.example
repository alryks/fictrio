# Production environment for infra/docker-compose.prod.yml.
# Copy to infra/.env.prod and fill in real secrets:
#   cp infra/.env.prod.example infra/.env.prod

# Public domain served by the existing Traefik instance.
DOMAIN=fictrio.sklyar.app

# Must match the existing Traefik setup on the host.
TRAEFIK_NETWORK=proxy
TRAEFIK_CERTRESOLVER=letsencrypt

# Baked into the web bundle at build time. Browser calls the API at this URL;
# Traefik strips the /api prefix before forwarding to the API container.
NEXT_PUBLIC_API_URL=https://fictrio.sklyar.app/api

# API
JWT_SECRET=replace-me-with-a-long-random-secret
JWT_ACCESS_TOKEN_EXPIRES_IN=1h

# PostgreSQL. Keep the password free of URL-reserved characters (@ : / ? # &)
# so the composed DATABASE_URL matches the credentials the app uses.
POSTGRES_DB=fictrio
POSTGRES_USER=fictrio
POSTGRES_PASSWORD=replace-me-with-a-strong-password

# Redis
REDIS_USERNAME=fictrio
REDIS_PASSWORD=replace-me-with-a-strong-password

# Content import (optional, run once after first deploy). Without a TMDb key
# only Open Library books can be imported.
TMDB_API_KEY=
TMDB_API_BASE_URL=https://api.themoviedb.org/3
IMPORT_TMDB_MOVIE_PAGES=2
IMPORT_TMDB_SHOW_PAGES=2
IMPORT_TMDB_SEASONS_PER_SHOW=

OPEN_LIBRARY_API_BASE_URL=https://openlibrary.org
OPEN_LIBRARY_COVERS_BASE_URL=https://covers.openlibrary.org
IMPORT_OPEN_LIBRARY_BOOK_LIMIT=50
IMPORT_OPEN_LIBRARY_SUBJECT=fiction
